# Biyard API base. Default: https://api.biyard.co
BIYARD_API_URL=https://api.biyard.co

# Biyard API key (Credential from console). NEVER expose to the browser.
BIYARD_API_KEY=biyard_xxx

# Biyard project id this partner is claiming for. The chain id is read from
# the token's metadata at runtime — no env var needed.
BIYARD_PROJECT_ID=proj_xxx
