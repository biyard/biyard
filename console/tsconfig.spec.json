{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.spec.tsbuildinfo",
    "types": ["vite/client", "@playwright/test"],
    /* Relax linting rules for test files */
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*.spec.ts", "src/**/*.spec.tsx", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "exclude": []
}
